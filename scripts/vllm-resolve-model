#!/usr/bin/env bash
# vllm-resolve-model — Multi-source model provisioning (identity-safe, cache-safe).
#
# Required:
#   VLLM_MODEL         — served/model basename label (must be a safe single path element)
#   VLLM_MODELS_DIR    — base dir for local models and optional HF cache
#
# Optional:
#   VLLM_MODEL_ID      — explicit HF model ID (org/name); derived if empty
#   VLLM_MODEL_ORG     — org prefix when deriving model ID from VLLM_MODEL
#   VLLM_MODEL_REVISION — optional immutable revision/pin for hf-cache/hf-hub and provenance
#   VLLM_MODEL_SOURCES — comma-separated source order (default: flox,local,hf-cache,r2,hf-hub)
#
#   FLOX_ENV           — Flox environment path (for flox source)
#   FLOX_ENV_CACHE     — cache directory (used to place env files by default)
#   VLLM_MODEL_ENV_FILE — override env file path
#     default: $FLOX_ENV_CACHE/vllm-model.<model_slug>.env   (per-model => no cross-model staleness)
#
#   R2_BUCKET          — Cloudflare R2 bucket name (for r2 source)
#   R2_MODELS_PREFIX   — R2 key prefix for models (for r2 source)
#   R2_MODEL_OBJECT_PREFIX — optional full object prefix for this model (recommended for immutable/versioned prefixes)
#   R2_ENDPOINT_URL    — optional AWS CLI endpoint URL (for r2 source)
#
#   VLLM_RESOLVE_LOCK_TIMEOUT — seconds to wait for lock (default: 300)
#   VLLM_SKIP_TOKENIZER_CHECK — set to 1 to skip tokenizer asset checks
#
# Local model directories are keyed to model identity (model id + optional revision), not just basename.
# Provisioned local directories include a provenance file and local reuse requires a provenance match.
#
# Logging:
#   By default, the script KEEPS logs on failure and deletes logs on success.
#   Set VLLM_KEEP_LOGS=1 to always keep logs (also on success).
#
# Output:
#   Writes an env file exporting:
#     HF_HOME (when applicable)
#     VLLM_MODEL, VLLM_MODEL_ID, VLLM_MODEL_PATH (when local), _VLLM_RESOLVED_MODEL, _VLLM_RESOLVED_VIA
#
# Notes:
# - The script NEVER "succeeds" by reusing an existing env file unless it resolved in the current run.
# - For r2 and hf-hub sources, it stages into a temp dir and swaps into place after validation.
#
# Permissions:
# - The script writes env files with private permissions by default (umask 077; chmod 600).

set -euo pipefail
umask 077

_die() { echo "ERROR: $*" >&2; exit 1; }
_warn() { echo "WARNING: $*" >&2; }

_trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

_has_cmd() { command -v "$1" >/dev/null 2>&1; }

_slugify() {
  printf '%s' "$1" | tr -cs 'A-Za-z0-9._-' '-'
}

_sha256_12() {
  local input="$1"
  if _has_cmd sha256sum; then
    printf '%s' "$input" | sha256sum | awk '{print substr($1,1,12)}'
    return 0
  fi
  if _has_cmd shasum; then
    printf '%s' "$input" | shasum -a 256 | awk '{print substr($1,1,12)}'
    return 0
  fi
  if _has_cmd openssl; then
    printf '%s' "$input" | openssl dgst -sha256 | awk '{print substr($NF,1,12)}'
    return 0
  fi
  if _has_cmd python3; then
    python3 -c "import hashlib,sys;print(hashlib.sha256(sys.argv[1].encode('utf-8')).hexdigest()[:12])" "$input"
    return 0
  fi
  return 1
}

# Require VLLM_MODEL to be a single safe path element.
_validate_model_name() {
  local name="$1"
  [[ -n "$name" ]] || _die "VLLM_MODEL is empty"
  [[ "$name" =~ ^[A-Za-z0-9._-]+$ ]] || _die "VLLM_MODEL must match ^[A-Za-z0-9._-]+$: $name"
  [[ "$name" != "." && "$name" != ".." ]] || _die "VLLM_MODEL must not be '.' or '..': $name"
}

_validate_revision() {
  local rev="$1"
  [[ -z "$rev" ]] && return 0
  [[ "$rev" =~ ^[A-Za-z0-9._-]+$ ]] || _die "VLLM_MODEL_REVISION must match ^[A-Za-z0-9._-]+\$: $rev"
  [[ "$rev" != "." && "$rev" != ".." ]] || _die "VLLM_MODEL_REVISION must not be '.' or '..': $rev"
}

_run_to_log() {
  # Usage: _run_to_log <logfile> <cmd...>
  local log="$1"; shift
  : >"$log"
  "$@" >>"$log" 2>&1
}

_tail_one_line() {
  local log="$1"
  local n="${2:-80}"
  tail -n "$n" "$log" 2>/dev/null | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g'
}

# Globals for richer diagnostics from _check_model_dir.
_CHECK_MODEL_ERR=""

# Parse HF shard index JSON and verify referenced shard files exist.
# Returns:
#   0 complete
#   1 missing shards
#   2 unparseable index
# Prints missing shard filenames to stdout (one per line) on rc=1.
_check_shard_index_complete() {
  local dir="$1"
  local idx="$2"

  if _has_cmd python3; then
    python3 - "$dir" "$idx" <<'PY'
import json, os, sys
d = sys.argv[1]
idx = sys.argv[2]
try:
  data = json.load(open(idx, "r", encoding="utf-8"))
except Exception:
  sys.exit(2)
wm = data.get("weight_map") or {}
if not isinstance(wm, dict):
  sys.exit(2)
req = sorted(set(wm.values()))
missing = [f for f in req if not os.path.exists(os.path.join(d, f))]
if missing:
  for f in missing[:2000]:
    print(f)
  sys.exit(1)
sys.exit(0)
PY
    return $?
  fi

  # Fallback heuristic if python3 is unavailable:
  mapfile -t shards < <(grep -oE '"[^"]+\.(safetensors|bin|pt|pth|gguf)"' "$idx" 2>/dev/null \
    | tr -d '"' | sort -u)

  if (( ${#shards[@]} == 0 )); then
    return 2
  fi

  local miss=0
  for f in "${shards[@]}"; do
    [[ -f "$dir/$f" ]] || { echo "$f"; miss=1; }
  done
  [[ $miss -eq 0 ]] && return 0 || return 1
}

# Tokenizer assets check (best-effort; widened for common layouts).
_check_tokenizer_assets() {
  local dir="$1"
  [[ "${VLLM_SKIP_TOKENIZER_CHECK:-0}" == "1" ]] && return 0

  local candidates=("$dir" "$dir/tokenizer" "$dir/tokenizer_files")
  local d
  for d in "${candidates[@]}"; do
    [[ -d "$d" ]] || continue
    if [[ -f "$d/tokenizer.json" || -f "$d/tokenizer.model" || -f "$d/spiece.model" ]]; then
      return 0
    fi
    if [[ -f "$d/vocab.json" && -f "$d/merges.txt" ]]; then
      return 0
    fi
    if [[ -f "$d/vocab.txt" ]]; then
      return 0
    fi
    if [[ -f "$d/tokenizer_config.json" && ( -f "$d/vocab.json" || -f "$d/vocab.txt" ) ]]; then
      return 0
    fi
  done
  return 1
}

# Heuristic for shard sets with no *.index.json:
# If we detect *-00001-of-000NN.ext, we require all shards 1..NN exist for that prefix/ext.
_check_of_shards_complete_no_index() {
  local dir="$1"
  local any=0
  local candidate bn prefix part_str total_str ext width total part need
  shopt -s nullglob
  local files=( "$dir"/*-00001-of-*.safetensors "$dir"/*-00001-of-*.bin "$dir"/*-00001-of-*.pt "$dir"/*-00001-of-*.pth "$dir"/*-00001-of-*.gguf )
  shopt -u nullglob

  for candidate in "${files[@]}"; do
    [[ -f "$candidate" ]] || continue
    bn="$(basename "$candidate")"
    # prefix-00001-of-00012.safetensors
    if [[ "$bn" =~ ^(.*)-([0-9]+)-of-([0-9]+)\.([A-Za-z0-9]+)$ ]]; then
      prefix="${BASH_REMATCH[1]}"
      part_str="${BASH_REMATCH[2]}"
      total_str="${BASH_REMATCH[3]}"
      ext="${BASH_REMATCH[4]}"
      [[ "$part_str" == "00001" || "$part_str" == "000001" || "$part_str" == "1" ]] || continue

      any=1
      width="${#part_str}"
      total=$((10#$total_str))

      # Guard against insane totals
      (( total > 0 && total < 100000 )) || { echo "<bad shard count: $bn>"; return 1; }

      local missing=()
      for ((part=1; part<=total; part++)); do
        part_str="$(printf "%0${width}d" "$part")"
        need="$dir/${prefix}-${part_str}-of-${total_str}.${ext}"
        [[ -f "$need" ]] || missing+=("$(basename "$need")")
      done

      if (( ${#missing[@]} == 0 )); then
        return 0
      else
        printf '%s\n' "${missing[@]}" | head -n 2000
        return 1
      fi
    fi
  done

  # No shard pattern detected => caller decides.
  (( any == 0 )) && return 2
  return 1
}

# Minimum viability for vLLM:
#   - config.json
#   - tokenizer assets (unless skipped)
#   - weights:
#       - if an index exists (*.index.json), verify all referenced shard files exist
#       - else require at least one weight-like file; if we detect "-00001-of-000NN", require full set
_check_model_dir() {
  local dir="$1"
  _CHECK_MODEL_ERR=""

  if [[ ! -f "$dir/config.json" ]]; then
    _CHECK_MODEL_ERR="missing config.json"
    return 1
  fi

  if ! _check_tokenizer_assets "$dir"; then
    _CHECK_MODEL_ERR="missing tokenizer assets (set VLLM_SKIP_TOKENIZER_CHECK=1 if this repo uses a nonstandard layout)"
    return 1
  fi

  shopt -s nullglob
  local index_files=( "$dir"/*.index.json )
  shopt -u nullglob

  if (( ${#index_files[@]} > 0 )); then
    local idx rc missing first_few
    for idx in "${index_files[@]}"; do
      # Preserve rc without fighting set -e.
      if missing="$(_check_shard_index_complete "$dir" "$idx")"; then
        rc=0
      else
        rc=$?
      fi

      if [[ $rc -eq 2 ]]; then
        _CHECK_MODEL_ERR="unparseable shard index $(basename "$idx") (install python3 to improve parsing)"
        return 1
      fi
      if [[ $rc -eq 1 ]]; then
        first_few="$(printf '%s\n' "$missing" | head -n 5 | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')"
        _CHECK_MODEL_ERR="missing shard files from $(basename "$idx") (first: ${first_few})"
        return 1
      fi
    done
    return 0
  fi

  # No index: detect common "-00001-of-000NN" and require full set.
  local missing_no_index rc_no_index first_few
  if missing_no_index="$(_check_of_shards_complete_no_index "$dir")"; then
    return 0
  else
    rc_no_index=$?
    if [[ $rc_no_index -eq 1 ]]; then
      first_few="$(printf '%s\n' "$missing_no_index" | head -n 5 | tr '\n' ' ' | sed 's/[[:space:]]\+/ /g')"
      _CHECK_MODEL_ERR="incomplete sharded weights (no index) (first missing: ${first_few})"
      return 1
    fi
    # rc=2 => no shard pattern detected; continue with "any weight exists" check.
  fi

  shopt -s nullglob
  local weights=(
    "$dir"/*.safetensors
    "$dir"/pytorch_model*.bin
    "$dir"/*.bin
    "$dir"/*.pt
    "$dir"/*.pth
    "$dir"/*.gguf
  )
  shopt -u nullglob

  if (( ${#weights[@]} == 0 )); then
    _CHECK_MODEL_ERR="missing weights files"
    return 1
  fi

  return 0
}

_verify_sha256sums() {
  local dir="$1"
  local sums_file="$2"
  local cache_file="$3"
  local use_cache="$4"

  local -A cached_entries=()
  if [[ "$use_cache" == "1" && -f "$cache_file" ]]; then
    local _first_line _cf _cm _cs _ch
    IFS= read -r _first_line < "$cache_file" || true
    if [[ "$_first_line" == "# schema=2" ]]; then
      while IFS=' ' read -r _cf _cm _cs _ch; do
        [[ "$_cf" == "#"* || -z "$_cf" ]] && continue
        cached_entries["$_cf"]="${_cm} ${_cs} ${_ch}"
      done < "$cache_file"
    fi
    # schema=1 or unrecognized: discard (forces one-time rehash on upgrade)
  fi

  local failed=0 checked=0
  local -a new_cache_lines=()
  new_cache_lines+=("# schema=2")

  while IFS= read -r line; do
    [[ -z "$line" || "$line" == "#"* ]] && continue
    local expected_hash file_rel
    expected_hash="${line%% *}"
    file_rel="${line#* }"
    # strip leading * or space (binary/text mode indicator from sha256sum)
    file_rel="${file_rel#\*}"
    file_rel="${file_rel# }"
    [[ -z "$file_rel" || -z "$expected_hash" ]] && continue

    local fpath="$dir/$file_rel"
    [[ -f "$fpath" ]] || { _warn "integrity: referenced file missing: $file_rel"; failed=1; continue; }

    local file_mtime file_size
    file_mtime="$(stat -c '%Y' "$fpath" 2>/dev/null || stat -f '%m' "$fpath" 2>/dev/null || echo 0)"
    file_size="$(stat -c '%s' "$fpath" 2>/dev/null || stat -f '%z' "$fpath" 2>/dev/null || echo 0)"

    if [[ "$use_cache" == "1" && -n "${cached_entries[$file_rel]:-}" ]]; then
      local cached_mtime cached_size cached_hash _cache_val
      _cache_val="${cached_entries[$file_rel]}"
      cached_mtime="${_cache_val%% *}"
      _cache_val="${_cache_val#* }"
      cached_size="${_cache_val%% *}"
      cached_hash="${_cache_val#* }"
      if [[ "$cached_mtime" == "$file_mtime" && "$cached_size" == "$file_size" && "$cached_hash" == "$expected_hash" ]]; then
        new_cache_lines+=("$file_rel $file_mtime $file_size $cached_hash")
        checked=$((checked + 1))
        continue
      fi
    fi

    local actual_hash
    if _has_cmd sha256sum; then
      actual_hash="$(sha256sum "$fpath" | awk '{print $1}')"
    elif _has_cmd shasum; then
      actual_hash="$(shasum -a 256 "$fpath" | awk '{print $1}')"
    elif _has_cmd openssl; then
      actual_hash="$(openssl dgst -sha256 "$fpath" | awk '{print $NF}')"
    else
      _warn "integrity: no sha256 tool available; skipping sha256sums verification"
      return 0
    fi

    if [[ "$actual_hash" != "$expected_hash" ]]; then
      _warn "integrity: SHA256 mismatch for $file_rel (expected $expected_hash, got $actual_hash)"
      failed=1
    else
      new_cache_lines+=("$file_rel $file_mtime $file_size $actual_hash")
      checked=$((checked + 1))
    fi
  done < "$sums_file"

  if [[ "$use_cache" == "1" && "$failed" -eq 0 && "$checked" -gt 0 ]]; then
    if [[ -w "$dir" ]] 2>/dev/null || [[ -w "$(dirname "$cache_file")" ]] 2>/dev/null; then
      printf '%s\n' "${new_cache_lines[@]}" > "$cache_file" 2>/dev/null || true
    fi
  fi

  return "$failed"
}

_verify_weight_sizes() {
  local dir="$1"
  shopt -s nullglob
  local wfiles=(
    "$dir"/*.safetensors
    "$dir"/pytorch_model*.bin
    "$dir"/*.bin
    "$dir"/*.pt
    "$dir"/*.pth
    "$dir"/*.gguf
  )
  shopt -u nullglob

  local f fsize max_size=0
  local -a sizes=()
  local -a names=()
  for f in "${wfiles[@]}"; do
    [[ -f "$f" ]] || continue
    fsize="$(stat -c '%s' "$f" 2>/dev/null || stat -f '%z' "$f" 2>/dev/null || echo 0)"
    if [[ "$fsize" -eq 0 ]]; then
      _warn "integrity: zero-byte weight file: $(basename "$f")"
      return 1
    fi
    sizes+=("$fsize")
    names+=("$(basename "$f")")
    (( fsize > max_size )) && max_size="$fsize"
  done

  # If largest weight > 1 MiB, flag any weight < 1 KiB as suspiciously truncated
  if (( max_size > 1048576 )); then
    local i
    for ((i=0; i<${#sizes[@]}; i++)); do
      if (( sizes[i] < 1024 )); then
        _warn "integrity: suspiciously small weight file: ${names[i]} (${sizes[i]} bytes vs largest ${max_size} bytes)"
        return 1
      fi
    done
  fi

  return 0
}

_check_model_integrity() {
  local dir="$1"

  [[ "${VLLM_SKIP_INTEGRITY_CHECK:-0}" == "1" ]] && return 0

  local use_cache="${VLLM_CACHE_INTEGRITY_HASH:-0}"
  local cache_file="$dir/.vllm-integrity-cache"

  # Strategy 1: sha256sums.txt
  if [[ -f "$dir/sha256sums.txt" ]]; then
    if _verify_sha256sums "$dir" "$dir/sha256sums.txt" "$cache_file" "$use_cache"; then
      return 0
    else
      return 1
    fi
  fi

  # Strategy 2: safetensors header validation (fast truncation check)
  shopt -s nullglob
  local st_files=( "$dir"/*.safetensors )
  shopt -u nullglob
  if (( ${#st_files[@]} > 0 )) && _has_cmd python3; then
    if ! python3 - "$dir" <<'PY'
import os, sys, struct, json

d = sys.argv[1]
errors = []
for fn in sorted(os.listdir(d)):
    if not fn.endswith(".safetensors"):
        continue
    fpath = os.path.join(d, fn)
    fsize = os.path.getsize(fpath)
    if fsize == 0:
        errors.append(f"zero-byte safetensors file: {fn}")
        continue
    if fsize < 8:
        errors.append(f"truncated safetensors file (< 8 bytes): {fn}")
        continue
    with open(fpath, "rb") as f:
        hdr_size_bytes = f.read(8)
    hdr_size = struct.unpack("<Q", hdr_size_bytes)[0]
    if hdr_size == 0 or hdr_size > fsize - 8:
        errors.append(f"invalid safetensors header size ({hdr_size}) in {fn}")
        continue
    with open(fpath, "rb") as f:
        f.seek(8)
        hdr_bytes = f.read(hdr_size)
    try:
        json.loads(hdr_bytes)
    except Exception:
        errors.append(f"corrupt safetensors header JSON in {fn}")

if errors:
    for e in errors:
        print(f"WARNING: integrity: {e}", file=sys.stderr)
    sys.exit(1)
sys.exit(0)
PY
    then
      _warn "integrity: safetensors header validation failed"
      return 1
    fi
    return 0
  fi

  # Strategy 3: weight size consistency check (fallback)
  _verify_weight_sizes "$dir"
  return $?
}

# Deterministic HF cache snapshot selection:
#   1) refs/main if present and valid
#   2) otherwise, snapshots sorted newest->oldest by mtime
# Echoes HF_HOME base_dir on success.
_check_hf_cache() {
  local base_dir="$1"
  local slug="$2"
  local requested_revision="${3:-}"
  local cache_dir="$base_dir/hub/models--$slug"

  [[ -d "$cache_dir/snapshots" ]] || return 1

  local ref rev snap snap_dir commit_sha

  if [[ -n "$requested_revision" ]]; then
    if [[ -d "$cache_dir/snapshots/$requested_revision" ]]; then
      snap="$cache_dir/snapshots/$requested_revision"
      if _check_model_dir "$snap" && _check_model_integrity "$snap"; then
        printf '%s\n%s' "$base_dir" "$requested_revision"
        return 0
      fi
    fi
    ref="$cache_dir/refs/$requested_revision"
    if [[ -f "$ref" ]]; then
      rev="$(<"$ref")"
      snap="$cache_dir/snapshots/$rev"
      if [[ -d "$snap" ]] && _check_model_dir "$snap" && _check_model_integrity "$snap"; then
        printf '%s\n%s' "$base_dir" "$rev"
        return 0
      fi
    fi
    _CHECK_MODEL_ERR="requested HF revision not present or invalid in cache: $requested_revision"
    return 1
  fi

  ref="$cache_dir/refs/main"
  if [[ -f "$ref" ]]; then
    rev="$(<"$ref")"
    snap="$cache_dir/snapshots/$rev"
    if [[ -d "$snap" ]] && _check_model_dir "$snap" && _check_model_integrity "$snap"; then
      printf '%s\n%s' "$base_dir" "$rev"
      return 0
    fi
  fi

  while IFS= read -r snap_dir; do
    [[ -d "$snap_dir" ]] || continue
    if _check_model_dir "${snap_dir%/}" && _check_model_integrity "${snap_dir%/}"; then
      commit_sha="$(basename "${snap_dir%/}")"
      printf '%s\n%s' "$base_dir" "$commit_sha"
      return 0
    fi
  done < <(ls -td "$cache_dir/snapshots"/*/ 2>/dev/null || true)

  return 1
}

_env_quote_value() {
  local s="$1"
  s=${s//\\/\\\\}
  s=${s//"/\\"}
  s=${s//$'\n'/\\n}
  s=${s//$'\t'/\\t}
  s=${s//$'\r'/\\r}
  printf '"%s"' "$s"
}

_write_env_atomically() {
  local env_file="$1"
  local hf_home="${2:-}"
  local model_id="$3"
  local model_path="${4:-}"
  local resolved_model="$5"
  local resolved_via="$6"
  local resolved_snapshot="${7:-}"

  local env_dir
  env_dir="$(dirname "$env_file")"
  mkdir -p "$env_dir"

  local tmp
  tmp="$(mktemp "${env_file}.tmp.XXXXXX")"
  {
    echo "# generated by vllm-resolve-model"
    [[ -n "$hf_home" ]] && printf 'export HF_HOME=%s\n' "$(_env_quote_value "$hf_home")"
    printf 'export VLLM_MODEL=%s\n' "$(_env_quote_value "$VLLM_MODEL")"
    printf 'export VLLM_MODEL_ID=%s\n' "$(_env_quote_value "$model_id")"
    [[ -n "${VLLM_MODEL_REVISION:-}" ]] && printf 'export VLLM_MODEL_REVISION=%s\n' "$(_env_quote_value "$VLLM_MODEL_REVISION")"
    [[ -n "$model_path" ]] && printf 'export VLLM_MODEL_PATH=%s\n' "$(_env_quote_value "$model_path")"
    printf 'export _VLLM_MODEL_IDENTITY=%s\n' "$(_env_quote_value "$_model_identity")"
    [[ -n "$model_path" ]] && printf 'export _VLLM_MODEL_DIR=%s\n' "$(_env_quote_value "$model_path")"
    [[ -n "$model_path" ]] && printf 'export _VLLM_MODEL_PROVENANCE_FILE=%s\n' "$(_env_quote_value "$model_path/$_provenance_file_name")"
    printf 'export _VLLM_RESOLVED_MODEL=%s\n' "$(_env_quote_value "$resolved_model")"
    printf 'export _VLLM_RESOLVED_VIA=%s\n' "$(_env_quote_value "$resolved_via")"
    [[ -n "$resolved_snapshot" ]] && printf 'export _VLLM_RESOLVED_SNAPSHOT=%s\n' "$(_env_quote_value "$resolved_snapshot")"
  } >"$tmp"

  mv -f "$tmp" "$env_file"
  chmod 600 "$env_file" 2>/dev/null || true
}

_now_utc() {
  if _has_cmd date; then
    date -u +%Y-%m-%dT%H:%M:%SZ
    return 0
  fi
  if _has_cmd python3; then
    python3 - <<'PY'
from datetime import datetime, timezone
print(datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ'))
PY
    return 0
  fi
  printf 'unknown'
}

_write_provenance_file() {
  local dir="$1"
  local resolved_via="$2"
  local detail="${3:-}"
  local tmp="$dir/${_provenance_file_name}.tmp.$$"
  {
    echo "schema=1"
    echo "complete=1"
    printf 'model=%s\n' "$VLLM_MODEL"
    printf 'model_id=%s\n' "$_model_id"
    printf 'model_identity=%s\n' "$_model_identity"
    printf 'identity_hash=%s\n' "$_identity_hash12"
    printf 'model_revision=%s\n' "${VLLM_MODEL_REVISION:-}"
    printf 'resolved_via=%s\n' "$resolved_via"
    printf 'detail=%s\n' "$detail"
    printf 'created_at=%s\n' "$(_now_utc)"
  } >"$tmp"
  mv -f "$tmp" "$dir/$_provenance_file_name"
  chmod 600 "$dir/$_provenance_file_name" 2>/dev/null || true
}

_read_provenance_value() {
  local file="$1"
  local key="$2"
  local line
  line="$(grep -m1 -E "^${key}=" "$file" 2>/dev/null || true)"
  printf '%s' "${line#*=}"
}

_check_local_provenance() {
  local dir="$1"
  local prov="$dir/$_provenance_file_name"
  [[ -f "$prov" ]] || { _CHECK_MODEL_ERR="missing provenance file $_provenance_file_name"; return 1; }

  local complete model model_id identity_hash revision identity
  complete="$(_read_provenance_value "$prov" complete)"
  model="$(_read_provenance_value "$prov" model)"
  model_id="$(_read_provenance_value "$prov" model_id)"
  identity="$(_read_provenance_value "$prov" model_identity)"
  identity_hash="$(_read_provenance_value "$prov" identity_hash)"
  revision="$(_read_provenance_value "$prov" model_revision)"

  [[ "$complete" == "1" ]] || { _CHECK_MODEL_ERR="provenance file is not marked complete"; return 1; }
  [[ "$model" == "$VLLM_MODEL" ]] || { _CHECK_MODEL_ERR="provenance basename mismatch (found: $model)"; return 1; }
  [[ "$model_id" == "$_model_id" ]] || { _CHECK_MODEL_ERR="provenance model_id mismatch (found: $model_id expected: $_model_id)"; return 1; }
  [[ "$identity" == "$_model_identity" ]] || { _CHECK_MODEL_ERR="provenance identity mismatch"; return 1; }
  [[ "$identity_hash" == "$_identity_hash12" ]] || { _CHECK_MODEL_ERR="provenance identity hash mismatch (found: $identity_hash expected: $_identity_hash12)"; return 1; }
  [[ "$revision" == "${VLLM_MODEL_REVISION:-}" ]] || { _CHECK_MODEL_ERR="provenance revision mismatch (found: $revision expected: ${VLLM_MODEL_REVISION:-})"; return 1; }
  return 0
}

_restore_backup_if_missing() {
  local target="$1"
  [[ -e "$target" ]] && return 0

  local newest_backup
  newest_backup="$(ls -td "${target}.bak."* 2>/dev/null | head -n 1 || true)"
  if [[ -n "$newest_backup" && -e "$newest_backup" ]]; then
    _warn "Target missing; restoring backup $(basename "$newest_backup")"
    mv "$newest_backup" "$target"
  fi
  return 0
}

_atomic_swap_dir() {
  # Replace target dir with staged dir using a backup+swap pattern.
  # If interrupted mid-swap, next run restores the newest backup.
  local staged="$1"
  local target="$2"

  _restore_backup_if_missing "$target"

  local backup="${target}.bak.$RANDOM$RANDOM"
  if [[ -e "$target" ]]; then
    mv "$target" "$backup"
  fi

  if mv "$staged" "$target"; then
    [[ -e "$backup" ]] && rm -rf "$backup"
    return 0
  fi

  [[ -e "$backup" ]] && mv "$backup" "$target" || true
  return 1
}

_mk_stage_dir() {
  # mktemp -d under stage base to avoid collisions.
  local base="$1"
  local prefix="$2"
  mktemp -d "${base%/}/${prefix}.XXXXXX"
}

# Download a full repo into a local dir, preferring stable tooling:
#   1) `hf download` (huggingface_hub)
#   2) `huggingface-cli download`
#   3) python snapshot_download (huggingface_hub)
_hf_download_repo_to_dir() {
  local repo_id="$1"
  local out_dir="$2"
  local log="$3"
  local revision="${4:-}"
  local rev_args=()
  [[ -n "$revision" ]] && rev_args+=(--revision "$revision")

  if _has_cmd hf; then
    _run_to_log "$log" hf download "$repo_id" --local-dir "$out_dir" "${rev_args[@]}"
    return $?
  fi

  if _has_cmd huggingface-cli; then
    if _run_to_log "$log" huggingface-cli download "$repo_id" --local-dir "$out_dir" --local-dir-use-symlinks False "${rev_args[@]}"; then
      return 0
    fi
    _run_to_log "$log" huggingface-cli download "$repo_id" --local-dir "$out_dir" "${rev_args[@]}"
    return $?
  fi

  if _has_cmd python3; then
    : >"$log"
    python3 - "$repo_id" "$out_dir" "$revision" >>"$log" 2>&1 <<'PY'
import sys
repo_id, out_dir, revision = sys.argv[1], sys.argv[2], sys.argv[3]
from huggingface_hub import snapshot_download
kwargs = dict(repo_id=repo_id, local_dir=out_dir, local_dir_use_symlinks=False)
if revision:
    kwargs["revision"] = revision
snapshot_download(**kwargs)
print(out_dir)
PY
    return $?
  fi

  echo "No Hugging Face download tool found (need hf, huggingface-cli, or python3+huggingface_hub)" >>"$log"
  return 127
}

# -------------------- inputs / defaults --------------------

: "${VLLM_MODEL:?Set VLLM_MODEL}"
: "${VLLM_MODELS_DIR:?Set VLLM_MODELS_DIR}"
_validate_model_name "$VLLM_MODEL"

VLLM_MODEL_ID="${VLLM_MODEL_ID:-}"
VLLM_MODEL_ORG="${VLLM_MODEL_ORG:-}"
VLLM_MODEL_REVISION="${VLLM_MODEL_REVISION:-}"
_validate_revision "$VLLM_MODEL_REVISION"
VLLM_MODEL_SOURCES="${VLLM_MODEL_SOURCES:-flox,local,hf-cache,r2,hf-hub}"
VLLM_RESOLVE_LOCK_TIMEOUT="${VLLM_RESOLVE_LOCK_TIMEOUT:-300}"
R2_MODEL_OBJECT_PREFIX="${R2_MODEL_OBJECT_PREFIX:-}"

mkdir -p "$VLLM_MODELS_DIR"

_model_id=""
if [[ -z "$VLLM_MODEL_ID" ]]; then
  [[ -n "$VLLM_MODEL_ORG" ]] || _die "VLLM_MODEL_ID is empty; set VLLM_MODEL_ORG to derive it."
  _model_id="$VLLM_MODEL_ORG/$VLLM_MODEL"
else
  _model_id="$VLLM_MODEL_ID"
fi

_model_identity="$_model_id"
if [[ -n "$VLLM_MODEL_REVISION" ]]; then
  _model_identity+="@${VLLM_MODEL_REVISION}"
fi

# Slug for filenames (safe chars only)
_model_slug="$(_slugify "$_model_id")"
# HF cache slug: HuggingFace uses "models--org--name" directory convention
_hf_slug="${_model_id//\//-\-}"
_provenance_file_name=".vllm-model-provenance"

if _identity_hash12="$(_sha256_12 "$_model_identity")"; then
  :
else
  _die "Unable to compute model identity hash"
fi

_target_dir="$VLLM_MODELS_DIR/${VLLM_MODEL}.${_identity_hash12}"
_legacy_target_dir="$VLLM_MODELS_DIR/$VLLM_MODEL"
_restore_backup_if_missing "$_target_dir"

# Per-model env file by default, keyed by full model identity
# (model_id plus @revision when VLLM_MODEL_REVISION is set).
VLLM_MODEL_ENV_FILE="${VLLM_MODEL_ENV_FILE:-}"
if [[ -z "$VLLM_MODEL_ENV_FILE" ]]; then
  : "${FLOX_ENV_CACHE:?Set FLOX_ENV_CACHE or override VLLM_MODEL_ENV_FILE}"
  VLLM_MODEL_ENV_FILE="$FLOX_ENV_CACHE/vllm-model.${_model_slug}.${_identity_hash12}.env"
fi
_model_env="$VLLM_MODEL_ENV_FILE"

# Ensure dirs exist before opening lock file (redirect would fail otherwise)
mkdir -p "$(dirname "$_model_env")"
mkdir -p "$VLLM_MODELS_DIR/.locks"

# Lock on the mutable target directory identity, not only the env file.
_lock_file="$VLLM_MODELS_DIR/.locks/vllm-model.${_identity_hash12}.lock"
_lock_dir="$VLLM_MODELS_DIR/.locks/vllm-model.${_identity_hash12}.lockdir"
_lock_mode=""

_try_reclaim_stale_lockdir() {
  local pid_file="$_lock_dir/pid"
  local host_file="$_lock_dir/host"
  local holder_pid holder_host current_host
  [[ -d "$_lock_dir" ]] || return 1
  [[ -f "$pid_file" && -f "$host_file" ]] || return 1
  holder_pid="$(<"$pid_file")"
  holder_host="$(<"$host_file")"
  current_host="$(hostname 2>/dev/null || printf 'unknown')"
  [[ "$holder_host" == "$current_host" ]] || return 1
  [[ "$holder_pid" =~ ^[0-9]+$ ]] || return 1
  if kill -0 "$holder_pid" 2>/dev/null; then
    return 1
  fi
  rm -rf "$_lock_dir" 2>/dev/null || return 1
  return 0
}

_acquire_lock() {
  if _has_cmd flock; then
    _lock_mode="flock"
    exec 9>"$_lock_file"
    flock -w "$VLLM_RESOLVE_LOCK_TIMEOUT" 9 || _die "lock timeout: $_lock_file"
    return 0
  fi

  _lock_mode="mkdir"
  local i
  for ((i=0; i<VLLM_RESOLVE_LOCK_TIMEOUT; i++)); do
    if mkdir "$_lock_dir" 2>/dev/null; then
      printf '%s
' "$$" >"$_lock_dir/pid"
      hostname 2>/dev/null >"$_lock_dir/host" || printf 'unknown
' >"$_lock_dir/host"
      return 0
    fi
    _try_reclaim_stale_lockdir || true
    sleep 1
  done
  _die "lock timeout: $_lock_dir"
}

_release_lock() {
  if [[ "$_lock_mode" == "mkdir" ]]; then
    rm -rf "$_lock_dir" 2>/dev/null || true
  fi
}

_resolved_via=""
_resolved_model=""
_did_resolve=0

_source_errors=""
_add_error() { _source_errors+=$'  '"$1"$'\n'; }

_stage_base="$VLLM_MODELS_DIR/.staging"
mkdir -p "$_stage_base"

# Track logs and stage dirs across attempts (avoid leaks between failed sources).
_logfiles=()
_stage_dirs=()

_cleanup_stages() {
  local sd
  for sd in "${_stage_dirs[@]}"; do
    [[ -n "$sd" && -d "$sd" ]] && rm -rf "$sd" || true
  done
}

_cleanup_logs_on_success() {
  local lf
  for lf in "${_logfiles[@]}"; do
    [[ -f "$lf" ]] && rm -f "$lf" || true
  done
}

cleanup() {
  # Always remove any leftover staging dirs from THIS run.
  _cleanup_stages

  # Keep logs on failure; delete on success unless VLLM_KEEP_LOGS=1.
  if [[ "${VLLM_KEEP_LOGS:-0}" != "1" && "${_did_resolve:-0}" -eq 1 ]]; then
    _cleanup_logs_on_success
  fi

  _release_lock
}
trap cleanup EXIT

_acquire_lock

IFS=',' read -ra _sources <<< "$VLLM_MODEL_SOURCES"
for _src in "${_sources[@]}"; do
  _src="$(_trim "$_src")"
  [[ -n "$_src" ]] || continue

  case "$_src" in
    flox)
      printf "[model] Checking flox package... "
      if [[ -z "${FLOX_ENV:-}" ]]; then
        echo "skipped (FLOX_ENV not set)"
        _add_error "flox: FLOX_ENV not set"
        continue
      fi
      if _hf_output=$(_check_hf_cache "$FLOX_ENV/share/models" "$_hf_slug" "$VLLM_MODEL_REVISION"); then
        _hf_home="$(head -n1 <<< "$_hf_output")"
        _hf_snapshot="$(tail -n1 <<< "$_hf_output")"
        _write_env_atomically "$_model_env" "$_hf_home" "$_model_id" "" "$_model_id" "flox" "$_hf_snapshot"
        _resolved_via="flox"; _resolved_model="$_model_id"; _did_resolve=1
        echo "OK"
        break
      else
        echo "not found"
        _add_error "flox: no usable HF snapshot at \$FLOX_ENV/share/models/hub/models--${_hf_slug}/ for revision ${VLLM_MODEL_REVISION:-<latest>}"
      fi
      ;;

    local)
      printf "[model] Checking local directory... "
      if _check_model_dir "$_target_dir" && _check_local_provenance "$_target_dir" && _check_model_integrity "$_target_dir"; then
        _write_env_atomically "$_model_env" "" "$_model_id" "$_target_dir" "$_target_dir" "local"
        _resolved_via="local"; _resolved_model="$_target_dir"; _did_resolve=1
        echo "OK"
        break
      else
        echo "not found"
        if [[ -d "$_legacy_target_dir" && "$_legacy_target_dir" != "$_target_dir" ]]; then
          _add_error "local: legacy path exists at $_legacy_target_dir but identity-scoped local path is $_target_dir; reprovision or migrate the directory with a matching provenance file"
        fi
        _add_error "local: $_target_dir failed validation/provenance check: ${_CHECK_MODEL_ERR}"
      fi
      ;;

    hf-cache)
      printf "[model] Checking HF cache... "
      if _hf_output=$(_check_hf_cache "$VLLM_MODELS_DIR" "$_hf_slug" "$VLLM_MODEL_REVISION"); then
        _hf_home="$(head -n1 <<< "$_hf_output")"
        _hf_snapshot="$(tail -n1 <<< "$_hf_output")"
        _write_env_atomically "$_model_env" "$_hf_home" "$_model_id" "" "$_model_id" "hf-cache" "$_hf_snapshot"
        _resolved_via="hf-cache"; _resolved_model="$_model_id"; _did_resolve=1
        echo "OK"
        break
      else
        echo "not found"
        _add_error "hf-cache: no usable HF snapshot at $VLLM_MODELS_DIR/hub/models--${_hf_slug}/ for revision ${VLLM_MODEL_REVISION:-<latest>} (last check: ${_CHECK_MODEL_ERR:-unknown})"
      fi
      ;;

    r2)
      printf "[model] Fetching from R2... "
      if ! _has_cmd aws; then
        echo "skipped (aws not found)"
        _add_error "r2: aws CLI not available in PATH"
        continue
      fi
      if [[ -z "${R2_BUCKET:-}" || -z "${R2_MODELS_PREFIX:-}" ]]; then
        echo "skipped (R2_BUCKET/R2_MODELS_PREFIX not set)"
        _add_error "r2: set R2_BUCKET and R2_MODELS_PREFIX"
        continue
      fi

      _r2_model_prefix="$R2_MODELS_PREFIX/$VLLM_MODEL"
      if [[ -n "$R2_MODEL_OBJECT_PREFIX" ]]; then
        _r2_model_prefix="$R2_MODEL_OBJECT_PREFIX"
      fi
      _r2_model_prefix="${_r2_model_prefix%/}"

      _aws_endpoint_args=()
      [[ -n "${R2_ENDPOINT_URL:-}" ]] && _aws_endpoint_args+=(--endpoint-url "$R2_ENDPOINT_URL")

      # Do not probe R2 with AWS STS. R2 presents an S3-compatible object API,
      # and the real operation we depend on is `aws s3 sync`. Let that command
      # be the source of truth for credentials, endpoint, and bucket access.
      _restore_backup_if_missing "$_target_dir"

      stage_dir="$(_mk_stage_dir "$_stage_base" "${VLLM_MODEL}.r2")"
      _stage_dirs+=("$stage_dir")

      logfile="$(mktemp "$_stage_base/${VLLM_MODEL}.r2.log.XXXXXX")"
      _logfiles+=("$logfile")

      if _run_to_log "$logfile" aws "${_aws_endpoint_args[@]}" s3 sync \
          "s3://$R2_BUCKET/${_r2_model_prefix#/}/" \
          "$stage_dir/" \
          --no-progress; then

        if _check_model_dir "$stage_dir" && _check_model_integrity "$stage_dir"; then
          _write_provenance_file "$stage_dir" "r2" "${_r2_model_prefix#/}"
          : >"$stage_dir/.complete"
          if _atomic_swap_dir "$stage_dir" "$_target_dir"; then
            _write_env_atomically "$_model_env" "" "$_model_id" "$_target_dir" "$_target_dir" "r2"
            _resolved_via="r2"; _resolved_model="$_target_dir"; _did_resolve=1
            echo "OK"
            break
          else
            echo "failed (swap error)"
            _add_error "r2: staged download validated, but swap into $_target_dir failed (see log: $logfile)"
          fi
        else
          echo "failed (incomplete after sync)"
          _add_error "r2: staged dir failed validation: ${_CHECK_MODEL_ERR} (see log: $logfile)"
        fi
      else
        echo "failed (sync error)"
        _add_error "r2: aws s3 sync failed (credentials, endpoint, bucket access, or object error) — tail: $(_tail_one_line "$logfile" 80) (full log: $logfile)"
      fi

      # Avoid stage-dir leaks across multiple remote attempts in one run.
      [[ -n "${stage_dir:-}" && -d "${stage_dir:-}" ]] && rm -rf "$stage_dir" || true
      stage_dir=""
      ;;

    hf-hub)
      printf "[model] Downloading from HuggingFace Hub... "
      _restore_backup_if_missing "$_target_dir"

      stage_dir="$(_mk_stage_dir "$_stage_base" "${VLLM_MODEL}.hf")"
      _stage_dirs+=("$stage_dir")

      logfile="$(mktemp "$_stage_base/${VLLM_MODEL}.hf.log.XXXXXX")"
      _logfiles+=("$logfile")

      if _hf_download_repo_to_dir "$_model_id" "$stage_dir" "$logfile" "$VLLM_MODEL_REVISION"; then
        if _check_model_dir "$stage_dir" && _check_model_integrity "$stage_dir"; then
          _write_provenance_file "$stage_dir" "hf-hub" "${VLLM_MODEL_REVISION:-}"
          : >"$stage_dir/.complete"
          if _atomic_swap_dir "$stage_dir" "$_target_dir"; then
            _write_env_atomically "$_model_env" "" "$_model_id" "$_target_dir" "$_target_dir" "hf-hub"
            _resolved_via="hf-hub"; _resolved_model="$_target_dir"; _did_resolve=1
            echo "OK"
            break
          else
            echo "failed (swap error)"
            _add_error "hf-hub: staged download validated, but swap into $_target_dir failed (see log: $logfile)"
          fi
        else
          echo "failed (incomplete after download)"
          _add_error "hf-hub: staged dir failed validation: ${_CHECK_MODEL_ERR} (see log: $logfile)"
        fi
      else
        echo "failed (download error)"
        _add_error "hf-hub: download failed — tail: $(_tail_one_line "$logfile" 80) (full log: $logfile)"
      fi

      # Avoid stage-dir leaks across multiple remote attempts in one run.
      [[ -n "${stage_dir:-}" && -d "${stage_dir:-}" ]] && rm -rf "$stage_dir" || true
      stage_dir=""
      ;;

    *)
      _warn "Unknown source '$_src' (skipping)"
      ;;
  esac
done

if [[ $_did_resolve -ne 1 ]]; then
  echo "" >&2
  echo "ERROR: Could not provision model '$VLLM_MODEL' ($_model_id) from any source." >&2
  echo "  Tried (VLLM_MODEL_SOURCES=$VLLM_MODEL_SOURCES):" >&2
  printf '%b' "$_source_errors" >&2

  if (( ${#_logfiles[@]} > 0 )); then
    echo "" >&2
    echo "  Logs kept for debugging:" >&2
    for lf in "${_logfiles[@]}"; do
      [[ -f "$lf" ]] && echo "    $lf" >&2
    done
    echo "  (Set VLLM_KEEP_LOGS=1 to keep logs even on success.)" >&2
  fi
  exit 1
fi

echo "[model] Resolved: $_resolved_model (via $_resolved_via)"
echo "[model] Env file: $_model_env"
