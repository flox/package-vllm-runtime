#!/usr/bin/env python3
# vllm-preflight — Pre-flight validation: port reclaim + GPU health check + guarded downstream startup.
#
# Platform: Linux only (requires /proc).
# Exit codes (stable contract):
#   0 success (or nothing to do)
#   1 general validation error / GPU hard failure / bad config
#   2 port owned by non-vLLM listener(s)
#   3 vLLM owned by different UID (blocked)
#   4 listener found but not attributable (permissions/hidepid)
#   5 attempted stop but port still listening
#
# Stdout/stderr contract:
#   - stderr: human logs, warnings, errors
#   - stdout: machine-readable output only when VLLM_PREFLIGHT_JSON=1 (single JSON line)
#
# JSON + downstream exec policy:
#   VLLM_PREFLIGHT_JSON=1 is incompatible with executing a downstream command.
#
# Downstream startup policy:
#   By default (VLLM_PREFLIGHT_PROXY_CHILD=1), this script starts the downstream command,
#   holds the lock until the child process tree owns the target listener, then releases the
#   lock and proxies signals / exit status for the child. Set VLLM_PREFLIGHT_PROXY_CHILD=0
#   to keep the older exec behavior.

import ctypes
import errno
import fcntl
import json
import os
import re
import shutil
import signal
import socket
import stat
import struct
import subprocess
import sys
import time
from collections import defaultdict
from ctypes import (
    POINTER,
    Structure,
    byref,
    c_char_p,
    c_int,
    c_uint,
    c_ulonglong,
    c_void_p,
)
from typing import Dict, Iterable, List, Optional, Sequence, Set, Tuple


_NVML_TEMPERATURE_GPU = 0
_NVML_PSTATE_UNKNOWN = 32


EXIT_GENERAL = 1
EXIT_NON_VLLM = 2
EXIT_OTHER_UID = 3
EXIT_UNATTRIBUTABLE = 4
EXIT_STILL_LISTENING = 5


class PreflightError(Exception):
    def __init__(self, code: int, message: str, payload: Optional[dict] = None, *, logged: bool = False):
        super().__init__(message)
        self.code = code
        self.message = message
        self.payload = payload or {}
        self.logged = logged


def log(msg: str) -> None:
    print(msg, file=sys.stderr)


def emit_json(obj: dict, want_json: bool) -> None:
    if want_json:
        print(json.dumps(obj, separators=(",", ":")))


def fail(code: int, message: str, want_json: bool, **payload) -> None:
    raise PreflightError(code, message, payload)


def getenv_str(name: str, default: str) -> str:
    return os.environ.get(name, default)


def getenv_bool01(name: str, default: str) -> bool:
    raw = getenv_str(name, default)
    if raw not in {"0", "1"}:
        raise PreflightError(EXIT_GENERAL, f"{name} must be 0 or 1 (got: {raw})")
    return raw == "1"


def getenv_int(name: str, default: str, *, min_value: Optional[int] = None, max_value: Optional[int] = None) -> int:
    raw = getenv_str(name, default)
    if not re.fullmatch(r"[0-9]+", raw):
        raise PreflightError(EXIT_GENERAL, f"{name} must be an integer (got: {raw})")
    value = int(raw)
    if min_value is not None and value < min_value:
        raise PreflightError(EXIT_GENERAL, f"{name} must be >= {min_value} (got: {raw})")
    if max_value is not None and value > max_value:
        raise PreflightError(EXIT_GENERAL, f"{name} must be <= {max_value} (got: {raw})")
    return value


def getenv_float(name: str, default: str, *, min_value: Optional[float] = None, max_value: Optional[float] = None, gt_zero: bool = False) -> float:
    raw = getenv_str(name, default)
    if not re.fullmatch(r"[0-9]+(?:\.[0-9]+)?", raw):
        raise PreflightError(EXIT_GENERAL, f"{name} must be numeric (got: {raw})")
    value = float(raw)
    if gt_zero and not (value > 0):
        raise PreflightError(EXIT_GENERAL, f"{name} must be > 0")
    if min_value is not None and value < min_value:
        raise PreflightError(EXIT_GENERAL, f"{name} must be >= {min_value} (got: {raw})")
    if max_value is not None and value > max_value:
        raise PreflightError(EXIT_GENERAL, f"{name} must be <= {max_value} (got: {raw})")
    return value


def parse_downstream(argv: Sequence[str]) -> List[str]:
    if not argv:
        return []
    if argv[0] == "--":
        argv = argv[1:]
    return list(argv)


def acquire_hardened_lock(lockfile: str) -> int:
    parent = os.path.dirname(lockfile) or "."
    name = os.path.basename(lockfile)

    parent_flags = os.O_RDONLY | getattr(os, "O_DIRECTORY", 0)
    if hasattr(os, "O_NOFOLLOW"):
        parent_flags |= os.O_NOFOLLOW

    try:
        parent_fd = os.open(parent, parent_flags)
    except FileNotFoundError:
        raise PreflightError(EXIT_GENERAL, f"Lockfile parent directory does not exist: {parent}")
    except NotADirectoryError:
        raise PreflightError(EXIT_GENERAL, f"Lockfile parent path is not a directory: {parent}")
    except OSError as e:
        raise PreflightError(EXIT_GENERAL, f"Failed to open lockfile parent directory safely: {parent}: {e}")

    try:
        flags = os.O_RDWR | os.O_APPEND | os.O_CREAT
        if hasattr(os, "O_NOFOLLOW"):
            flags |= os.O_NOFOLLOW
        try:
            fd = os.open(name, flags, 0o600, dir_fd=parent_fd)
        except OSError as e:
            if e.errno in (errno.ELOOP, errno.EMLINK):
                raise PreflightError(EXIT_GENERAL, f"Lockfile path is a symlink or unsafe path: {lockfile}")
            raise PreflightError(EXIT_GENERAL, f"Failed to open lockfile safely: {lockfile}: {e}")

        st = os.fstat(fd)
        if not stat.S_ISREG(st.st_mode):
            os.close(fd)
            raise PreflightError(EXIT_GENERAL, f"Lockfile is not a regular file: {lockfile}")

        try:
            fcntl.flock(fd, fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            os.close(fd)
            raise PreflightError(EXIT_GENERAL, f"Another vllm-preflight is running (lock: {lockfile})")

        os.set_inheritable(fd, False)
        return fd
    finally:
        os.close(parent_fd)


def read_int(path: str, default: int = 0) -> int:
    try:
        with open(path, "r", encoding="utf-8") as fh:
            return int(fh.read().strip())
    except Exception:
        return default


def encode_ipv4(addr: str) -> str:
    if addr in ("0.0.0.0", ""):
        return "00000000"
    packed = socket.inet_aton(addr)
    return struct.pack("<I", struct.unpack(">I", packed)[0]).hex().upper()


def encode_ipv6(addr: str) -> str:
    if addr in ("::", ""):
        return "0" * 32
    packed = socket.inet_pton(socket.AF_INET6, addr)
    words = [packed[i:i+4][::-1] for i in range(0, 16, 4)]
    return b"".join(words).hex().upper()


def parse_proc_net(path: str) -> Iterable[Tuple[str, str, str]]:
    try:
        with open(path, "r", encoding="utf-8") as fh:
            next(fh, None)
            for line in fh:
                fields = line.split()
                if len(fields) < 10:
                    continue
                yield fields[1].upper(), fields[3], fields[9]
    except FileNotFoundError:
        return


def resolve_ips(host: str, port: int) -> List[str]:
    if host in ("", "0.0.0.0", "::"):
        return [host]
    addrs: Set[str] = set()
    try:
        infos = socket.getaddrinfo(host, port, type=socket.SOCK_STREAM)
    except socket.gaierror as e:
        raise PreflightError(
            EXIT_GENERAL,
            f"VLLM_HOST could not be resolved: {host} ({e})",
            {"host": host, "port": port},
        )
    for family, _, _, _, sockaddr in infos:
        if family in (socket.AF_INET, socket.AF_INET6):
            addrs.add(sockaddr[0])
    if not addrs:
        raise PreflightError(
            EXIT_GENERAL,
            f"VLLM_HOST resolved to no usable TCP addresses: {host}",
            {"host": host, "port": port},
        )
    return sorted(addrs)


def build_targets(host: str, port: int) -> Tuple[Set[str], Set[str]]:
    port_hex = f"{port:04X}"
    ips = resolve_ips(host, port)
    bindv6only = read_int("/proc/sys/net/ipv6/bindv6only", 0)
    has_v6 = any(":" in ip for ip in ips) or host == "::"

    v4_targets: Set[str] = set()
    v6_targets: Set[str] = set()

    for ip in ips:
        if ":" in ip:
            try:
                v6_targets.add(f"{encode_ipv6(ip)}:{port_hex}")
            except OSError:
                pass
        else:
            try:
                v4_targets.add(f"{encode_ipv4(ip)}:{port_hex}")
            except OSError:
                pass

    v4_targets.add(f"{encode_ipv4('0.0.0.0')}:{port_hex}")
    if has_v6 or bindv6only == 0:
        v6_targets.add(f"{encode_ipv6('::')}:{port_hex}")
    return v4_targets, v6_targets


def find_listen_inodes(host: str, port: int) -> Set[str]:
    v4_targets, v6_targets = build_targets(host, port)
    inodes: Set[str] = set()
    for local_addr, state, inode in parse_proc_net("/proc/net/tcp"):
        if state == "0A" and local_addr in v4_targets:
            inodes.add(inode)
    for local_addr, state, inode in parse_proc_net("/proc/net/tcp6"):
        if state == "0A" and local_addr in v6_targets:
            inodes.add(inode)
    return inodes


def pid_uid(pid: int) -> Optional[int]:
    try:
        st = os.stat(f"/proc/{pid}")
        return st.st_uid
    except Exception:
        return None


def pid_cmdline(pid: int) -> str:
    try:
        with open(f"/proc/{pid}/cmdline", "rb") as fh:
            data = fh.read()
        if not data:
            return ""
        return data.replace(b"\x00", b" ").decode("utf-8", "replace").strip()
    except Exception:
        return ""


def pid_ppid(pid: int) -> Optional[int]:
    try:
        with open(f"/proc/{pid}/status", "r", encoding="utf-8") as fh:
            for line in fh:
                if line.startswith("PPid:"):
                    return int(line.split()[1])
    except Exception:
        return None
    return None


def pid_starttime(pid: int) -> Optional[int]:
    try:
        with open(f"/proc/{pid}/stat", "r", encoding="utf-8") as fh:
            parts = fh.read().split()
        if len(parts) >= 22:
            return int(parts[21])
    except Exception:
        return None
    return None


def pid_exists(pid: int) -> bool:
    return os.path.exists(f"/proc/{pid}")


def pid_state(pid: int) -> Optional[str]:
    try:
        with open(f"/proc/{pid}/status", "r", encoding="utf-8") as fh:
            for line in fh:
                if line.startswith("State:"):
                    parts = line.split()
                    if len(parts) >= 2:
                        return parts[1]
    except Exception:
        return None
    return None


def is_zombie(pid: int) -> bool:
    return pid_state(pid) == "Z"


def inode_to_pids(target_inodes: Set[str]) -> Tuple[Set[int], bool, bool]:
    pids: Set[int] = set()
    could_scan = False
    had_perm_errors = False
    for name in os.listdir("/proc"):
        if not name.isdigit():
            continue
        pid = int(name)
        fd_dir = f"/proc/{pid}/fd"
        try:
            entries = os.listdir(fd_dir)
        except PermissionError:
            had_perm_errors = True
            continue
        except FileNotFoundError:
            continue
        except OSError:
            continue
        could_scan = True
        for entry in entries:
            path = os.path.join(fd_dir, entry)
            try:
                target = os.readlink(path)
            except (FileNotFoundError, PermissionError):
                continue
            except OSError:
                continue
            m = re.fullmatch(r"socket:\[(\d+)\]", target)
            if m and m.group(1) in target_inodes:
                pids.add(pid)
                break
    return pids, could_scan, had_perm_errors


def build_parent_chain(pid: int) -> List[int]:
    chain = [pid]
    seen = {pid}
    current = pid
    while True:
        parent = pid_ppid(current)
        if parent is None or parent <= 1 or parent in seen:
            break
        chain.append(parent)
        seen.add(parent)
        current = parent
    return chain


_VLLM_SIGNATURES = [
    "vllm.entrypoints.openai.api_server",
    "vllm.entrypoints.api_server",
    "vllm.entrypoints.openai.run_server",
    "vllm serve",
    "vllm.entrypoints",
]


def classify_vllm_processes(pids: Iterable[int], extra_signatures: Optional[List[str]] = None) -> Tuple[Set[int], Set[int]]:
    signatures = _VLLM_SIGNATURES + (extra_signatures or [])
    vllm_pids: Set[int] = set()
    non_vllm_pids: Set[int] = set()
    for pid in pids:
        chain = build_parent_chain(pid)
        cmdlines = [pid_cmdline(x) for x in chain]
        if any(any(sig in c for sig in signatures) for c in cmdlines):
            vllm_pids.add(pid)
        else:
            non_vllm_pids.add(pid)
    return vllm_pids, non_vllm_pids


def uid_or_unknown(pid: int) -> str:
    uid = pid_uid(pid)
    return str(uid) if uid is not None else "unknown"


def get_descendants(root: int) -> Set[int]:
    children: Dict[int, List[int]] = defaultdict(list)
    for name in os.listdir("/proc"):
        if not name.isdigit():
            continue
        pid = int(name)
        parent = pid_ppid(pid)
        if parent is not None:
            children[parent].append(pid)
    out: Set[int] = set()
    stack = [root]
    while stack:
        pid = stack.pop()
        if pid in out:
            continue
        out.add(pid)
        stack.extend(children.get(pid, []))
    return out


def stop_process_tree(root: int, grace_seconds: int) -> None:
    snapshot = sorted(get_descendants(root), reverse=True)
    for pid in snapshot:
        try:
            os.kill(pid, signal.SIGTERM)
        except ProcessLookupError:
            pass
        except PermissionError:
            pass
    deadline = time.time() + grace_seconds
    while time.time() < deadline:
        alive = [pid for pid in snapshot if pid_exists(pid) and not is_zombie(pid)]
        if not alive:
            return
        time.sleep(0.2)
    for pid in snapshot:
        try:
            os.kill(pid, signal.SIGKILL)
        except ProcessLookupError:
            pass
        except PermissionError:
            pass
    deadline = time.time() + 2.0
    while time.time() < deadline:
        alive = [pid for pid in snapshot if pid_exists(pid) and not is_zombie(pid)]
        if not alive:
            return
        time.sleep(0.1)


def check_port_and_reclaim(host: str, port: int, stop_timeout: int, allow_other_uid_kill: bool, want_json: bool, dry_run: bool, extra_signatures: Optional[List[str]] = None) -> Tuple[str, Set[int], Set[int], bool]:
    inodes = find_listen_inodes(host, port)
    if not inodes:
        return "clear", set(), set(), False

    pids, could_scan, had_perm_errors = inode_to_pids(inodes)
    if not pids:
        if had_perm_errors:
            raise PreflightError(EXIT_UNATTRIBUTABLE,
                f"Listener(s) found on {host}:{port} but /proc fd attribution was blocked (hidepid/permissions?)",
                {"host": host, "port": port})
        if could_scan:
            raise PreflightError(EXIT_UNATTRIBUTABLE,
                f"Listener(s) found on {host}:{port} but owning process exited before attribution (race condition)",
                {"host": host, "port": port})
        raise PreflightError(EXIT_UNATTRIBUTABLE,
            f"Listener(s) found on {host}:{port} but no /proc entries could be scanned",
            {"host": host, "port": port})

    vllm_pids, non_vllm_pids = classify_vllm_processes(pids, extra_signatures)
    if non_vllm_pids:
        payload = {
            "host": host,
            "port": port,
            "pids": sorted(non_vllm_pids),
            "cmdlines": {str(pid): pid_cmdline(pid) for pid in sorted(non_vllm_pids)},
        }
        raise PreflightError(
            EXIT_NON_VLLM,
            f"Port {host}:{port} is owned by non-vLLM listener(s): {', '.join(str(p) for p in sorted(non_vllm_pids))}",
            payload,
        )

    me = os.getuid()
    signatures = _VLLM_SIGNATURES + (extra_signatures or [])
    roots: Set[int] = set()
    for pid in sorted(vllm_pids):
        chain = build_parent_chain(pid)
        root = pid
        for candidate in chain:
            cmd = pid_cmdline(candidate)
            if any(sig in cmd for sig in signatures):
                root = candidate
        roots.add(root)

    blocked = [pid for pid in sorted(roots) if pid_uid(pid) not in (None, me)]
    if blocked and not allow_other_uid_kill:
        payload = {
            "host": host,
            "port": port,
            "pids": blocked,
            "uids": {str(pid): uid_or_unknown(pid) for pid in blocked},
            "cmdlines": {str(pid): pid_cmdline(pid) for pid in blocked},
        }
        raise PreflightError(
            EXIT_OTHER_UID,
            f"vLLM listener(s) on {host}:{port} belong to different UID(s): {', '.join(str(p) for p in blocked)}",
            payload,
        )

    if dry_run:
        return "would-reclaim", roots, set(blocked), True

    for root in sorted(roots):
        stop_process_tree(root, stop_timeout)

    remaining = find_listen_inodes(host, port)
    if remaining:
        rem_pids, _, _ = inode_to_pids(remaining)
        payload = {
            "host": host,
            "port": port,
            "pids": sorted(rem_pids),
            "cmdlines": {str(pid): pid_cmdline(pid) for pid in sorted(rem_pids)},
        }
        raise PreflightError(
            EXIT_STILL_LISTENING,
            f"After attempted stop, port {host}:{port} is still listening",
            payload,
        )

    return "reclaimed", roots, set(blocked), True


def _dlopen_first(names: List[str]):
    """Try to dlopen the first available shared library from a list of names."""
    for name in names:
        try:
            return ctypes.CDLL(name)
        except OSError:
            continue
    return None


def _cuda_driver_probe() -> dict:
    """Probe CUDA driver via ctypes dlopen of libcuda.so.1.

    Returns dict with keys: driver_present, device_count, driver_version, error.
    """
    out = {
        "driver_present": False,
        "device_count": 0,
        "driver_version": None,
        "error": None,
    }
    lib = _dlopen_first(["libcuda.so.1", "libcuda.so"])
    if not lib:
        out["error"] = "CUDA driver library not found (libcuda.so.1)."
        return out

    try:
        cuInit = lib.cuInit
        cuInit.argtypes = [c_uint]
        cuInit.restype = c_int

        cuDeviceGetCount = lib.cuDeviceGetCount
        cuDeviceGetCount.argtypes = [POINTER(c_int)]
        cuDeviceGetCount.restype = c_int

        cuDriverGetVersion = getattr(lib, "cuDriverGetVersion", None)
        if cuDriverGetVersion is not None:
            cuDriverGetVersion.argtypes = [POINTER(c_int)]
            cuDriverGetVersion.restype = c_int

        rc = cuInit(0)
        if rc != 0:
            out["error"] = f"CUDA driver init failed (cuInit returned {rc})."
            return out

        n = c_int(0)
        rc = cuDeviceGetCount(byref(n))
        if rc != 0:
            out["error"] = f"CUDA device query failed (cuDeviceGetCount returned {rc})."
            return out

        out["driver_present"] = True
        out["device_count"] = int(n.value)

        if cuDriverGetVersion is not None:
            v = c_int(0)
            rc = cuDriverGetVersion(byref(v))
            if rc == 0:
                out["driver_version"] = int(v.value)

        return out
    except Exception as e:
        out["error"] = f"CUDA probe raised: {e}"
        return out


def _gpu_check_nvml(min_free_gb: float, max_temp_c: int, max_util_pct: int, target_devices: Optional[str], fail_on: Set[str]) -> Optional[Tuple[List[dict], List[str]]]:
    """Tier 1: GPU health via ctypes NVML/CUDA driver probe.

    Returns None if neither libcuda.so.1 nor libnvidia-ml.so.1 can be loaded (fall through to nvidia-smi).
    """
    # Phase 1 — CUDA driver probe (gate)
    cuda = _cuda_driver_probe()
    if not cuda["driver_present"]:
        if cuda["error"]:
            log(f"WARNING: CUDA driver probe: {cuda['error']}")
        return None  # fall through to nvidia-smi

    if cuda["device_count"] == 0:
        raise PreflightError(
            EXIT_GENERAL,
            "CUDA driver present but 0 devices visible. "
            "If running in a container, ensure it was started with GPU access "
            "(e.g. --gpus all or NVIDIA_VISIBLE_DEVICES=all).",
        )

    if cuda.get("driver_version"):
        v = cuda["driver_version"]
        log(f"INFO: CUDA driver version {v // 1000}.{(v % 1000) // 10}")

    # Phase 2 — NVML detailed query
    lib = _dlopen_first(["libnvidia-ml.so.1", "libnvidia-ml.so"])
    if not lib:
        log("WARNING: CUDA driver present but libnvidia-ml.so.1 not found; falling through")
        return None

    def _nvml_err_str(code: int) -> str:
        try:
            fn = lib.nvmlErrorString
            fn.argtypes = [c_int]
            fn.restype = c_char_p
            s = fn(code)
            return s.decode("utf-8", "replace") if s else f"NVML error {code}"
        except Exception:
            return f"NVML error {code}"

    def _nvml_call(fn, *args):
        rc = fn(*args)
        if rc != 0:
            raise RuntimeError(_nvml_err_str(int(rc)))

    init_fn = getattr(lib, "nvmlInit_v2", None) or getattr(lib, "nvmlInit", None)
    shutdown_fn = getattr(lib, "nvmlShutdown", None)
    if init_fn is None or shutdown_fn is None:
        log("WARNING: NVML init/shutdown symbols missing; falling through")
        return None

    init_fn.restype = c_int
    shutdown_fn.restype = c_int

    try:
        _nvml_call(init_fn)
    except RuntimeError as e:
        log(f"WARNING: NVML init failed: {e}; falling through")
        return None

    try:
        get_count = getattr(lib, "nvmlDeviceGetCount_v2", None) or getattr(lib, "nvmlDeviceGetCount", None)
        get_handle = getattr(lib, "nvmlDeviceGetHandleByIndex_v2", None) or getattr(lib, "nvmlDeviceGetHandleByIndex", None)
        get_mem = getattr(lib, "nvmlDeviceGetMemoryInfo", None)

        if not (get_count and get_handle and get_mem):
            log("WARNING: NVML device query symbols missing; falling through")
            return None

        get_count.argtypes = [POINTER(c_uint)]
        get_count.restype = c_int

        get_handle.argtypes = [c_uint, POINTER(c_void_p)]
        get_handle.restype = c_int

        class NvmlMemory(Structure):
            _fields_ = [("total", c_ulonglong), ("free", c_ulonglong), ("used", c_ulonglong)]

        get_mem.argtypes = [c_void_p, POINTER(NvmlMemory)]
        get_mem.restype = c_int

        # Optional NVML functions
        get_temp = getattr(lib, "nvmlDeviceGetTemperature", None)
        if get_temp:
            get_temp.argtypes = [c_void_p, c_int, POINTER(c_uint)]
            get_temp.restype = c_int

        get_util = getattr(lib, "nvmlDeviceGetUtilizationRates", None)

        class NvmlUtilization(Structure):
            _fields_ = [("gpu", c_uint), ("memory", c_uint)]

        if get_util:
            get_util.argtypes = [c_void_p, POINTER(NvmlUtilization)]
            get_util.restype = c_int

        get_pstate = getattr(lib, "nvmlDeviceGetPerformanceState", None)
        if get_pstate:
            get_pstate.argtypes = [c_void_p, POINTER(c_int)]
            get_pstate.restype = c_int

        get_clocks = getattr(lib, "nvmlDeviceGetCurrentClocksEventReasons", None)
        if get_clocks:
            get_clocks.argtypes = [c_void_p, POINTER(c_ulonglong)]
            get_clocks.restype = c_int

        cnt = c_uint(0)
        _nvml_call(get_count, byref(cnt))

        # Build set of target device indices if specified
        target_indices: Optional[Set[int]] = None
        if target_devices:
            target_indices = set()
            for part in target_devices.split(","):
                part = part.strip()
                if part.isdigit():
                    target_indices.add(int(part))
                else:
                    # Non-numeric device spec (UUID, etc.) — query all, let NVML/driver handle visibility
                    target_indices = None
                    break

        per_gpu: List[dict] = []
        failures: List[str] = []
        min_free_mib = int(min_free_gb * 1024)

        for idx in range(int(cnt.value)):
            if target_indices is not None and idx not in target_indices:
                continue

            h = c_void_p()
            _nvml_call(get_handle, c_uint(idx), byref(h))

            # Memory (required)
            mem = NvmlMemory()
            _nvml_call(get_mem, h, byref(mem))
            total_mib = int(mem.total // (1024 * 1024))
            free_mib = int(mem.free // (1024 * 1024))

            # Temperature (optional)
            temperature_c: Optional[int] = None
            if get_temp:
                try:
                    temp_val = c_uint(0)
                    _nvml_call(get_temp, h, c_int(_NVML_TEMPERATURE_GPU), byref(temp_val))
                    temperature_c = int(temp_val.value)
                except Exception:
                    pass

            # Utilization (optional)
            utilization_pct: Optional[int] = None
            if get_util:
                try:
                    util = NvmlUtilization()
                    _nvml_call(get_util, h, byref(util))
                    utilization_pct = int(util.gpu)
                except Exception:
                    pass

            # Performance state (optional)
            pstate: Optional[str] = None
            if get_pstate:
                try:
                    ps = c_int(0)
                    _nvml_call(get_pstate, h, byref(ps))
                    ps_val = int(ps.value)
                    if ps_val != _NVML_PSTATE_UNKNOWN:
                        pstate = f"P{ps_val}"
                except Exception:
                    pass

            # Clock event reasons (optional)
            clocks_event_reasons: Optional[str] = None
            if get_clocks:
                try:
                    reasons = c_ulonglong(0)
                    _nvml_call(get_clocks, h, byref(reasons))
                    clocks_event_reasons = f"0x{int(reasons.value):016x}"
                except Exception:
                    pass

            # Threshold checks
            warnings: List[str] = []
            if free_mib < min_free_mib:
                msg = f"GPU {idx} low free memory: {free_mib / 1024:.1f} GiB < {min_free_gb:.1f} GiB"
                if "memory" in fail_on:
                    failures.append(msg)
                else:
                    warnings.append(msg)
            if temperature_c is not None and temperature_c > max_temp_c:
                msg = f"GPU {idx} temperature too high: {temperature_c}C > {max_temp_c}C"
                if "temperature" in fail_on:
                    failures.append(msg)
                else:
                    warnings.append(msg)
            if utilization_pct is not None and utilization_pct > max_util_pct:
                msg = f"GPU {idx} high utilization: {utilization_pct}% > {max_util_pct}%"
                if "utilization" in fail_on:
                    failures.append(msg)
                else:
                    warnings.append(msg)
            if clocks_event_reasons is not None and clocks_event_reasons not in ("0x0000000000000000",):
                warnings.append(f"GPU {idx} clocks event active: {clocks_event_reasons}")

            per_gpu.append(
                {
                    "index": idx,
                    "memory_total_mib": total_mib,
                    "memory_free_mib": free_mib,
                    "temperature_c": temperature_c,
                    "utilization_pct": utilization_pct,
                    "pstate": pstate,
                    "clocks_event_reasons_active": clocks_event_reasons,
                    "warnings": warnings,
                }
            )

        if not per_gpu:
            raise PreflightError(EXIT_GENERAL, "NVML reports 0 GPUs after device filtering")

        return per_gpu, failures
    except PreflightError:
        raise
    except RuntimeError as e:
        log(f"WARNING: NVML query failed: {e}; falling through")
        return None
    finally:
        try:
            shutdown_fn()
        except Exception:
            pass


def _gpu_check_nvidia_smi(min_free_gb: float, max_temp_c: int, max_util_pct: int, target_devices: Optional[str], fail_on: Set[str]) -> Optional[Tuple[List[dict], List[str]]]:
    """Tier 2: GPU health via nvidia-smi. Returns None if nvidia-smi unavailable or exec fails."""
    exe = shutil.which("nvidia-smi")
    if not exe:
        log("WARNING: nvidia-smi not found in PATH")
        return None

    cmd = [
        exe,
        "--query-gpu=index,memory.total,memory.free,temperature.gpu,utilization.gpu,pstate,clocks_event_reasons.active",
        "--format=csv,noheader,nounits",
    ]
    if target_devices:
        cmd.append(f"--id={target_devices}")
    try:
        proc = subprocess.run(
            cmd,
            capture_output=True,
            text=True,
            check=False,
        )
    except OSError as e:
        log(f"WARNING: Failed to execute nvidia-smi: {e}")
        return None
    if proc.returncode != 0:
        msg = proc.stderr.strip() or proc.stdout.strip() or "nvidia-smi failed"
        log(f"WARNING: nvidia-smi returned non-zero exit code: {msg}")
        return None

    rows: List[List[str]] = []
    for line in proc.stdout.strip().splitlines():
        parts = [x.strip() for x in line.split(",")]
        if len(parts) < 7:
            raise PreflightError(EXIT_GENERAL, f"Unexpected nvidia-smi output row: {line}")
        rows.append(parts[:7])
    if not rows:
        raise PreflightError(EXIT_GENERAL, "No GPUs reported by nvidia-smi")

    per_gpu: List[dict] = []
    failures: List[str] = []
    min_free_mib = int(min_free_gb * 1024)

    for parts in rows:
        idx_s, total_s, free_s, temp_s, util_s, pstate, clocks_reason = parts
        try:
            idx = int(idx_s)
            total_mib = int(float(total_s))
            free_mib = int(float(free_s))
            temp_c = int(float(temp_s))
            util_pct = int(float(util_s))
        except ValueError:
            raise PreflightError(EXIT_GENERAL, f"Unparseable nvidia-smi row: {parts}")

        warnings: List[str] = []
        if free_mib < min_free_mib:
            msg = f"GPU {idx} low free memory: {free_mib / 1024:.1f} GiB < {min_free_gb:.1f} GiB"
            if "memory" in fail_on:
                failures.append(msg)
            else:
                warnings.append(msg)
        if temp_c > max_temp_c:
            msg = f"GPU {idx} temperature too high: {temp_c}C > {max_temp_c}C"
            if "temperature" in fail_on:
                failures.append(msg)
            else:
                warnings.append(msg)
        if util_pct > max_util_pct:
            msg = f"GPU {idx} high utilization: {util_pct}% > {max_util_pct}%"
            if "utilization" in fail_on:
                failures.append(msg)
            else:
                warnings.append(msg)
        if clocks_reason not in ("N/A", "None", "Not Active", "", "0", "0x0000000000000000"):
            warnings.append(f"GPU {idx} clocks event active: {clocks_reason}")

        per_gpu.append(
            {
                "index": idx,
                "memory_total_mib": total_mib,
                "memory_free_mib": free_mib,
                "temperature_c": temp_c,
                "utilization_pct": util_pct,
                "pstate": pstate,
                "clocks_event_reasons_active": clocks_reason,
                "warnings": warnings,
            }
        )

    return per_gpu, failures


def evaluate_gpu_health(min_free_gb: float, max_temp_c: int, max_util_pct: int, want_json: bool, target_devices: Optional[str] = None, fail_on: Optional[Set[str]] = None) -> Tuple[List[dict], List[str], str]:
    if fail_on is None:
        fail_on = {"temperature"}

    # Tier 1: NVML (ctypes probe of libcuda.so.1 / libnvidia-ml.so.1)
    result = _gpu_check_nvml(min_free_gb, max_temp_c, max_util_pct, target_devices, fail_on)
    if result is not None:
        log("INFO: GPU health check via NVML")
        per_gpu, failures = result
        return per_gpu, failures, "nvml"

    # Tier 2: nvidia-smi
    result = _gpu_check_nvidia_smi(min_free_gb, max_temp_c, max_util_pct, target_devices, fail_on)
    if result is not None:
        log("INFO: GPU health check via nvidia-smi")
        per_gpu, failures = result
        return per_gpu, failures, "nvidia-smi"

    # Tier 3: no GPU tooling available
    log("WARNING: No GPU health check available (NVML and nvidia-smi both unavailable); proceeding without GPU validation")
    return [], [], "skipped"


def build_success_payload(host: str, port: int, port_action: str, reclaimed_roots: Set[int], blocked_roots: Set[int], could_scan: bool, per_gpu: List[dict], gpu_check_source: Optional[str] = None) -> dict:
    payload = {
        "ok": True,
        "host": host,
        "port": port,
        "port_action": port_action,
        "reclaimed_roots": sorted(reclaimed_roots),
        "blocked_roots": sorted(blocked_roots),
        "could_scan": could_scan,
        "gpus": per_gpu,
    }
    if gpu_check_source is not None:
        payload["gpu_check_source"] = gpu_check_source
    return payload


def proc_tree_contains_listener_pids(root_pid: int, listener_pids: Set[int]) -> bool:
    if not listener_pids:
        return False
    try:
        descendants = get_descendants(root_pid)
    except Exception:
        descendants = {root_pid}
    return any(pid in descendants for pid in listener_pids)


def wait_for_child_bind(root_pid: int, host: str, port: int, timeout_s: float, poll_s: float, child: Optional[subprocess.Popen] = None) -> Tuple[bool, Optional[str], Set[int]]:
    deadline = time.time() + timeout_s
    last_detail: Optional[str] = None

    while time.time() < deadline:
        if child is not None:
            rc = child.poll()
            if rc is not None:
                return False, f"child exited (rc={rc}) before binding target port", set()
        elif not pid_exists(root_pid):
            return False, "child exited before binding target port", set()

        try:
            inodes = find_listen_inodes(host, port)
        except PreflightError as e:
            return False, e.message, set()

        if inodes:
            pids, could_scan, had_perm_errors = inode_to_pids(inodes)
            if pids and proc_tree_contains_listener_pids(root_pid, pids):
                return True, None, pids
            if pids:
                last_detail = f"port owned by unrelated pid(s): {', '.join(str(p) for p in sorted(pids))}"
            elif had_perm_errors:
                last_detail = "listener detected but could not attribute (permissions)"
            elif could_scan:
                last_detail = "listener detected but owning process exited before match"
            else:
                last_detail = "listener detected but no /proc entries could be scanned"

        time.sleep(poll_s)

    return False, last_detail or f"child did not bind {host}:{port} within timeout", set()


def forward_signal_to_pgrp(child_pid: int, signum: int) -> None:
    try:
        os.killpg(child_pid, signum)
    except ProcessLookupError:
        pass
    except PermissionError:
        pass


def install_signal_forwarders(child_pid: int) -> None:
    handled = [
        signal.SIGINT,
        signal.SIGTERM,
        signal.SIGHUP,
        signal.SIGQUIT,
        signal.SIGUSR1,
        signal.SIGUSR2,
    ]

    def _handler(signum, _frame):
        forward_signal_to_pgrp(child_pid, signum)

    for sig in handled:
        try:
            signal.signal(sig, _handler)
        except Exception:
            continue


def wait_child_exit(child: subprocess.Popen) -> int:
    rc = child.wait()
    if rc >= 0:
        return rc
    return 128 + (-rc)


def launch_and_proxy(downstream: Sequence[str], host: str, port: int, lock_fd: int, bind_timeout: float, bind_poll: float, want_json: bool) -> int:
    try:
        child = subprocess.Popen(list(downstream), preexec_fn=os.setsid)
    except OSError as e:
        raise PreflightError(EXIT_GENERAL, f"Failed to start downstream command: {e}")

    ok, detail, bind_pids = wait_for_child_bind(child.pid, host, port, bind_timeout, bind_poll, child=child)
    if not ok:
        forward_signal_to_pgrp(child.pid, signal.SIGTERM)
        time.sleep(0.5)
        forward_signal_to_pgrp(child.pid, signal.SIGKILL)
        rc = wait_child_exit(child)
        msg = detail or "downstream command failed before owning listener"
        raise PreflightError(
            EXIT_STILL_LISTENING,
            f"Downstream command did not take ownership of {host}:{port}: {msg}",
            {"host": host, "port": port, "child_pid": child.pid, "listener_pids": sorted(bind_pids), "child_exit_code": rc},
        )

    os.close(lock_fd)
    install_signal_forwarders(child.pid)
    return wait_child_exit(child)


def exec_downstream(downstream: Sequence[str]) -> None:
    os.execvp(downstream[0], list(downstream))


def main(argv: Sequence[str]) -> int:
    want_json = getenv_bool01("VLLM_PREFLIGHT_JSON", "0")
    dry_run = getenv_bool01("VLLM_DRY_RUN", "0")
    allow_other_uid_kill = getenv_bool01("VLLM_ALLOW_OTHER_UID_KILL", "0")
    proxy_child = getenv_bool01("VLLM_PREFLIGHT_PROXY_CHILD", "1")
    skip_gpu_check = getenv_bool01("VLLM_SKIP_GPU_CHECK", "0")

    host = getenv_str("VLLM_HOST", "0.0.0.0")
    port = getenv_int("VLLM_PORT", "8000", min_value=1, max_value=65535)
    stop_timeout = getenv_int("VLLM_STOP_TIMEOUT", "15", min_value=0)
    min_free_gb = getenv_float("VLLM_MIN_FREE_GPU_GB", "4", min_value=0)
    max_temp_c = getenv_int("VLLM_MAX_GPU_TEMP_C", "85", min_value=1)
    max_util_pct = getenv_int("VLLM_MAX_GPU_UTIL_PCT", "95", min_value=0, max_value=100)

    fail_on_raw = getenv_str("VLLM_GPU_FAIL_ON", "temperature")
    fail_on = {s.strip().lower() for s in fail_on_raw.split(",") if s.strip()}
    _valid_fail_on = {"temperature", "memory", "utilization"}
    unknown_tokens = fail_on - _valid_fail_on
    if unknown_tokens:
        raise PreflightError(EXIT_GENERAL, f"VLLM_GPU_FAIL_ON contains unknown token(s): {', '.join(sorted(unknown_tokens))}. Valid: {', '.join(sorted(_valid_fail_on))}")

    bind_timeout = getenv_float("VLLM_START_BIND_TIMEOUT", "60", gt_zero=True)
    bind_poll = getenv_float("VLLM_START_BIND_POLL", "0.2", gt_zero=True)

    extra_sigs_raw = getenv_str("VLLM_PROCESS_SIGNATURES", "")
    extra_signatures = [s.strip() for s in extra_sigs_raw.split(",") if s.strip()] if extra_sigs_raw else None

    downstream = parse_downstream(argv[1:])
    if want_json and downstream:
        raise PreflightError(EXIT_GENERAL, "VLLM_PREFLIGHT_JSON=1 cannot be used with a downstream command")

    lockfile = getenv_str("VLLM_PREFLIGHT_LOCKFILE", f"/tmp/vllm-preflight.{port}.lock")
    lock_fd = acquire_hardened_lock(lockfile)

    try:
        port_action, reclaimed_roots, blocked_roots, could_scan = check_port_and_reclaim(
            host,
            port,
            stop_timeout,
            allow_other_uid_kill,
            want_json,
            dry_run,
            extra_signatures,
        )

        per_gpu: List[dict] = []
        gpu_check_source: Optional[str] = None
        if skip_gpu_check:
            log("INFO: VLLM_SKIP_GPU_CHECK=1; skipping GPU health check")
        else:
            target_devices = getenv_str("VLLM_GPU_DEVICES", "") or os.environ.get("CUDA_VISIBLE_DEVICES", "")
            per_gpu, gpu_failures, gpu_check_source = evaluate_gpu_health(min_free_gb, max_temp_c, max_util_pct, want_json, target_devices or None, fail_on=fail_on)
            if gpu_failures:
                raise PreflightError(
                    EXIT_GENERAL,
                    "; ".join(gpu_failures),
                    {"host": host, "port": port, "gpus": per_gpu},
                )

        payload = build_success_payload(host, port, port_action, reclaimed_roots, blocked_roots, could_scan, per_gpu, gpu_check_source=gpu_check_source)
        emit_json(payload, want_json)

        if want_json:
            return 0

        for gpu in per_gpu:
            for warning in gpu.get("warnings", []):
                log(f"WARNING: {warning}")

        if downstream:
            if dry_run:
                log("INFO: VLLM_DRY_RUN=1 set; skipping downstream command")
                return 0
            if proxy_child:
                return launch_and_proxy(downstream, host, port, lock_fd, bind_timeout, bind_poll, want_json)
            os.close(lock_fd)
            exec_downstream(downstream)
            return 0

        return 0
    finally:
        try:
            os.close(lock_fd)
        except OSError:
            pass


if __name__ == "__main__":
    try:
        sys.exit(main(sys.argv))
    except PreflightError as e:
        if not e.logged:
            log(f"ERROR: {e.message}")
        want_json = os.environ.get("VLLM_PREFLIGHT_JSON", "0") == "1"
        payload = {"ok": False, "code": e.code, "error": e.message}
        payload.update(e.payload)
        emit_json(payload, want_json)
        sys.exit(e.code)
